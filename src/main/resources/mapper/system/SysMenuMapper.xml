<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.zhq.taskforge.model.system.mapper.SysMenuMapper">

    <!-- 通用结果映射：把数据库字段映射到实体类属性 -->
    <resultMap id="sysMenuMap" type="com.zhq.taskforge.model.system.entity.SysMenu">
        <id column="menu_id" property="menuId" />
        <result column="menu_name" property="menuName" />
        <result column="parent_id" property="parentId" />
        <result column="order_num" property="orderNum" />
        <result column="path" property="path" />
        <result column="component" property="component" />
        <result column="query" property="query" />
        <result column="is_frame" property="isFrame" />
        <result column="is_cache" property="isCache" />
        <result column="menu_type" property="menuType" />
        <result column="visible" property="visible" />
        <result column="status" property="status" />
        <result column="perms" property="perms" />
        <result column="icon" property="icon" />
        <result column="create_by" property="createBy" />
        <result column="create_time" property="createTime" />
        <result column="update_by" property="updateBy" />
        <result column="update_time" property="updateTime" />
        <result column="remark" property="remark" />
    </resultMap>

    <select id="selectPermsByUserId" resultType="String">
    select perms from sys_user_role sur
    inner join sys_role sr on sur.role_id = sr.role_id
    inner join sys_role_menu srm on srm.role_id = sr.role_id
    inner join sys_menu sm on sm.menu_id = srm.menu_id
    where sur.user_id =#{userId}
    and sr.status = 0
    and sr.deleted = 0
    and sm.status = 0
    and sm.perms is not null
    and sm.perms != '';
    </select>


</mapper>